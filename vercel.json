{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/scrape", "destination": "/api/scrape" },
    { "source": "/api/proxy-image", "destination": "/api/proxy-image" },
    { "source": "/api/omni-embed-url", "destination": "/api/omni-embed-url" },
    { "source": "/api/omni-dashboards", "destination": "/api/omni-dashboards" },
    { "source": "/api/omni-connections", "destination": "/api/omni-connections" },
    { "source": "/api/omni-dashboard-filters", "destination": "/api/omni-dashboard-filters" },
    { "source": "/api/omni-query-distinct", "destination": "/api/omni-query-distinct" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
